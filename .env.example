# ─── Identity ─────────────────────────────────────────────────────────────────
# The SFU's Nostr keypair. Generate one with `npm run generate-keys`.
# ALL events the SFU publishes (kind 31313 advertisement, 31314 active-call,
# 20078 presence, 25050 signaling) are signed by this key.
SFU_NSEC=

# Operator pubkey (hex). Anyone with this key can issue control events
# regardless of the allow-list. If unset, defaults to the SFU's own pubkey
# (i.e. the SFU operates itself — fine for solo deployments).
SFU_OPERATOR_PUBKEY=

# ─── Allow-list ───────────────────────────────────────────────────────────────
# Pubkeys (hex, comma-separated) authorized to publish kind 25052 `start`
# events on this SFU. Empty = nobody can start a call (the operator can
# still test by setting SFU_OPERATOR_PUBKEY and using their own key).
#
# For larger lists, prefer the file form: create services/sfu/allow.json
# with `{ "pubkeys": ["...", "..."] }`. The file is reloaded on SIGHUP.
SFU_ALLOWED_PUBKEYS=

# ─── Relays ───────────────────────────────────────────────────────────────────
# Comma-separated WSS URLs the SFU subscribes to AND publishes on.
# At minimum, include the relay your group uses for chat — the SFU joins
# voice channels on whichever relay carries the kind 39001/39002 group state.
SFU_RELAYS=wss://public.obelisk.ar

# Comma-separated WSS URLs the SFU subscribes to ONLY FOR CONTROL EVENTS
# (kind 25052 `start`/`end`/`kick`/`update`). Events seen on these relays
# are treated as authorized — i.e., the relay's own write-whitelist IS
# the SFU's allow-list for this category. The SFU does NOT need to be
# whitelisted on these relays itself; only read access is required.
#
# This is the production deploy idiom: point at a permissioned relay
# where the obelisk admins have already curated who's allowed to host
# big-room calls. Combined with the per-call deny/allow lists in the
# `start` payload, this is enough — `allow.json` becomes empty.
#
# Leave blank to require allow.json for all start events.
SFU_TRUSTED_AUTHOR_RELAYS=wss://relay.obelisk.ar

# ─── Capacity ─────────────────────────────────────────────────────────────────
SFU_MAX_PARTICIPANTS_PER_ROOM=50
SFU_MAX_ROOMS=10
# Empty room is dropped after this many seconds of zero participants.
SFU_EMPTY_GRACE_SECONDS=300

# ─── Networking ───────────────────────────────────────────────────────────────
# HTTP server port — exposed via Cloudflare tunnel for /healthz, /, /rooms.
SFU_HTTP_PORT=4848

# Public IP for ICE candidates. Required if the SFU is behind 1:1 NAT
# (AWS, GCP, etc) where the host doesn't see its own public address.
# Leave blank on a VPS with a directly attached public IP.
SFU_PUBLIC_IP=

# UDP port range for RTP. Must be open on the host firewall.
# 100 ports is enough for ~10 simultaneous rooms.
SFU_RTP_PORT_MIN=40000
SFU_RTP_PORT_MAX=40099

# ─── STUN / TURN ──────────────────────────────────────────────────────────────
# Comma-separated. Public Google + Cloudflare STUN are fine in most cases.
SFU_STUN_URLS=stun:stun.l.google.com:19302,stun:stun.cloudflare.com:3478

# Optional TURN — fill in if SFU is behind symmetric NAT or you want a
# guaranteed path for peers behind tough firewalls.
SFU_TURN_URLS=
SFU_TURN_USERNAME=
SFU_TURN_CREDENTIAL=

# ─── Logging ──────────────────────────────────────────────────────────────────
# debug | info | warn | error
SFU_LOG_LEVEL=info

# ─── Public URL (advertised in kind 31313) ────────────────────────────────────
# The Cloudflare tunnel hostname. Cosmetic — the actual signaling is via
# Nostr — but clients display this as the "hosted by" badge.
SFU_PUBLIC_URL=https://sfu.example.com

# Free-form region hint surfaced in the advertisement. e.g. us-east, eu-west.
SFU_REGION=
